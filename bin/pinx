#!/usr/bin/env php
<?php

$projectRoot = dirname(__DIR__);
$corePathResolver = $projectRoot . '/platform/launcher/core-path.php';

if (is_file($corePathResolver)) {
    require_once $corePathResolver;
}

$pinxCliPath = function_exists('pinoox_resolve_configured_pinx_cli_path')
    ? pinoox_resolve_configured_pinx_cli_path($projectRoot)
    : $projectRoot . '/vendor/pinoox/pinx-cli';

require rtrim($pinxCliPath, '/\\') . '/bin/pinx';
